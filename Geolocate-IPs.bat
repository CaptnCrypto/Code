@echo off
setlocal

:: ============================================================
:: Geolocate-IPs.bat  (single-file version)
::
:: Reads IP addresses from a .txt or .csv file, geolocates each
:: one via ip-api.com, and writes IP / Location / ISP to a new
:: CSV file. Everything is self-contained in this one .bat file
:: - no companion .ps1 file required.
::
:: Usage:
::   Geolocate-IPs.bat input.txt
::   Geolocate-IPs.bat input.csv output.csv
::   (or just double-click and enter the path when prompted)
::
:: Requires internet access and Windows PowerShell (built into
:: Windows 7+). Uses the free ip-api.com endpoint (no key
:: required). That free tier is rate-limited (~45 req/min) and
:: its terms restrict it to non-commercial use - for official
:: use, get a paid ip-api key and put it in the $ApiKey line
:: inside the embedded script below (search for "ApiKey").
:: ============================================================

set "INPUT=%~1"
if "%INPUT%"=="" (
    echo No input file was given on the command line.
    set /p "INPUT=Enter the full path to your .txt or .csv file: "
)

if "%INPUT%"=="" (
    echo No input file provided. Exiting.
    echo.
    pause
    exit /b 1
)

if not exist "%INPUT%" (
    echo ERROR: Input file not found: %INPUT%
    echo.
    pause
    exit /b 1
)

set "OUTPUT=%~2"
set "GEOLOCATE_INPUT=%INPUT%"
set "GEOLOCATE_OUTPUT=%OUTPUT%"

set "B64FILE=%TEMP%\geo_b64_%RANDOM%.txt"
if exist "%B64FILE%" del "%B64FILE%" >nul 2>&1

